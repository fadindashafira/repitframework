FoamFile
{
    format          ascii;
    class           volVectorField;
    location        "18";
    object          U;
}

dimensions      [ 0 1 -1 0 0 0 0 ];

boundaryField
{
    hot
    {
        type            noSlip;
    }
    cold
    {
        type            noSlip;
    }
    topAndBottom
    {
        type            noSlip;
    }
    frontAndBack
    {
        type            empty;
    }
}

internalField   nonuniform ( 1 , 2 , 3 );


